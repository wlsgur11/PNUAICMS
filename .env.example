# ─────────────────────────────────────────────────────────
# 부울경 AI기업 CMS v2 — 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요. (.env 는 git 에 올라가지 않음)
# ─────────────────────────────────────────────────────────

# [필수] PostgreSQL 연결 문자열
#  - Supabase 사용 시: 프로젝트 → Settings → Database → Connection string → "URI"
#    · 앱 런타임(서버리스)에는 6543 포트(pgbouncer, Transaction mode)를 권장:
#      DATABASE_URL="postgresql://postgres.xxxx:[PW]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#    · prisma migrate/db push 같은 스키마 작업에는 5432 직결(DIRECT_URL)을 권장.
#  - 나중에 교내 서버 Docker 로 옮기면 이 값만 로컬 Postgres 로 교체하면 된다.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# [선택] 자동조회 외부 API 키 — 없으면 자동조회 기능만 비활성, 나머지는 정상 동작
#  - DART: https://opendart.fss.or.kr 에서 발급 (40자)
DART_API_KEY=""
#  - 네이버 검색 API: https://developers.naver.com 애플리케이션 등록
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# [데모용] 인증 스텁에서 사용할 가짜 로그인 사용자
#  - 운영 전환 시 NextAuth(Google, @pusan.ac.kr 제한)로 교체 예정 (src/lib/auth.ts 참고)
DEMO_USER_EMAIL="demo@pusan.ac.kr"
DEMO_USER_NAME="데모 사용자"

# [데모 보호] 사이트 전체 공유 비밀번호 (Basic 인증, src/middleware.ts)
#  - 설정하면 접속 시 브라우저 로그인 창이 뜨고 이 비밀번호를 입력해야 들어옴.
#  - 비워두면 잠금 해제(누구나 접근). 영문/숫자 권장.
SITE_PASSWORD=""
