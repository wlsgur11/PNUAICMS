# ─────────────────────────────────────────────────────────
# AI 산학협력 관리 시스템 - 환경변수 예시
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요. (.env 는 git 에 올라가지 않음)
# ─────────────────────────────────────────────────────────

# [필수] PostgreSQL 연결 문자열
#  - Supabase 사용 시: 프로젝트 > Settings > Database > Connection string > "URI"
#    · 앱 런타임(서버리스)에는 6543 포트(pgbouncer, Transaction mode)를 권장:
#      DATABASE_URL="postgresql://postgres.xxxx:[PW]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#    · prisma migrate/db push 같은 스키마 작업에는 5432 직결(DIRECT_URL)을 권장.
#  - 나중에 교내 서버 Docker 로 옮기면 이 값만 로컬 Postgres 로 교체하면 된다.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# [필수] NextAuth (Auth.js) v5 인증 설정
#  - Google OAuth 로 @pusan.ac.kr 도메인만 로그인 허용
#
#  발급 방법:
#   1) https://console.cloud.google.com 접속 > 프로젝트 선택(또는 생성)
#   2) 'APIs & Services' > 'Credentials' > 'Create Credentials' > 'OAuth client ID'
#   3) Application type: Web application
#   4) Authorized redirect URIs 두 개 등록:
#       - https://pnuaicms.vercel.app/api/auth/callback/google
#       - http://localhost:3000/api/auth/callback/google
#   5) 발급된 Client ID/Secret 을 아래에 붙여넣기
#
#  Vercel 배포 시: Project Settings > Environment Variables 에서 동일한 키로 등록
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# [필수] NextAuth 세션 토큰 서명용 비밀키 (32바이트 랜덤 문자열)
#  생성 방법:
#   PowerShell:
#     [Convert]::ToBase64String((1..32 | ForEach-Object {Get-Random -Minimum 0 -Maximum 256}))
#   Bash/macOS:
#     openssl rand -base64 32
#   또는 npx auth secret
AUTH_SECRET=""

# [선택] 로그인 우회 스위치 (개발/시연 임시용)
#  - "true" 로 두면 로그인 없이 테스트 계정으로 접근됨.
#  - 로컬 개발에서 Google OAuth 설정 없이 빠르게 띄울 때만 사용.
#  - !! 운영(main/Vercel)에서는 반드시 "false" 또는 미설정 !! (인증 전체 무력화됨)
AUTH_BYPASS="false"

# [권장] 접근 허용 이메일 화이트리스트 (쉼표 구분)
#  - 설정하면 @pusan.ac.kr 중에서도 "이 목록의 계정만" 로그인·접근 가능.
#  - 비워두면 @pusan.ac.kr 도메인 전체 허용(기존 동작). 개인정보 보호상 담당자 목록 지정 권장.
#  - Vercel/서버 운영 env 에도 동일하게 등록.
#  예) ALLOWED_EMAILS="prof@pusan.ac.kr, staff1@pusan.ac.kr, staff2@pusan.ac.kr"
ALLOWED_EMAILS=""

# [선택] 자동조회 외부 API 키 - 없으면 자동조회 기능만 비활성, 나머지는 정상 동작
#  - DART: https://opendart.fss.or.kr 에서 발급 (40자)
DART_API_KEY=""
#  - 네이버 검색 API: https://developers.naver.com 애플리케이션 등록
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""
