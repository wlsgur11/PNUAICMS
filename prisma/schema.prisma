// ─────────────────────────────────────────────────────────
// 부울경 AI기업 관리 시스템 v2 — 데이터 모델
//
// v1(Google Sheets)의 4개 시트를 정규화 테이블로 옮긴 것.
//  - 기업기본정보  → Company
//  - 협업정보(1:1) → Collaboration
//  - 실무자정보(1:N) → ContactPerson
//  - 컨택이력_협력성과(1:N) → ContactHistory
//
// v1 대비 개선점:
//  1) version 컬럼 + @updatedAt 으로 "낙관적 락" → 동시 편집 충돌 감지 (시트의 last-update-wins 해결)
//  2) 외래키 + soft delete(isActive)로 관계 무결성 보장 (시트의 FK 깨짐 방지)
//  3) ID 자동 채번을 DB 시퀀스가 담당 (시트의 _시스템 카운터 불필요)
// ─────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase pgbouncer 사용 시 마이그레이션은 직결(5432)로. 로컬/Docker면 둘 다 같은 값이어도 됨.
  directUrl = env("DIRECT_URL")
}

// ── 1. 기업기본정보 ─────────────────────────────────────
model Company {
  id             String  @id @default(cuid())
  // 표시용 사람이 읽는 코드(C-001 ...). 화면·검색용. 채번은 애플리케이션에서.
  code           String  @unique
  name           String  @unique // 기관명 (중복 등록 방지)
  joinYear       Int? // 사업참여연도
  region         String? // 지역구분: 부산/울산/경남/수도권/기타
  addressDetail  String? // 소재지(상세)
  orgType        String? // 유형: 기업/공공기관/연구소/대학
  employeeCount  String? // 직원수 (범위 문자열 허용)
  revenueScale   String? // 매출규모 (라벨)
  avgSalary      String? // 평균연봉
  newcomerSalary String? // 신입사원연봉
  homepage       String?
  mainIndustry   String? // 주요산업분야
  aiField        String? // AI기술분야
  professor1     String? // 교육원담당교수명1
  professor2     String? // 교육원담당교수명2
  mou            Boolean @default(false) // MOU체결여부
  priority       String? // 협력우선순위: A/B/C
  status         String  @default("미접촉") // 진행상태
  summary        String? // 기업 소개 (위키피디아 자동조회 요약)
  note           String? // 비고 (자동조회 메타 마커 포함)

  isActive  Boolean  @default(true) // soft delete (false = 비활성)
  version   Int      @default(1) // 낙관적 락 버전
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // 등록자(이메일)
  updatedBy String? // 수정자(이메일)

  collaboration Collaboration?
  persons       ContactPerson[]
  histories     ContactHistory[]
  projects      Project[]
  internships   Internship[]

  @@index([name])
  @@index([region])
  @@index([status])
  @@map("companies")
}

// ── 2. 협업정보 (기업 1:1) ──────────────────────────────
model Collaboration {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  internship          Boolean @default(false) // 인턴십여부
  industryProject     Boolean @default(false) // 산학프로젝트여부
  curriculumCommittee Boolean @default(false) // 교과과정혁신위원회여부
  guestLecture        Boolean @default(false) // 특강연계여부
  employment          Boolean @default(false) // 채용연계여부
  fieldTrainingOrg    Boolean @default(false) // 표준현장실습기관등록여부
  overseasEducation   Boolean @default(false) // 해외교육여부
  valueSpread         Boolean @default(false) // 가치확산여부
  startup             Boolean @default(false) // 창업
  etc                 Boolean @default(false) // 기타협력

  // 인턴십/채용연계 상세 (교수님 시안의 카드 내용)
  requiredSkills String? // 요구역량 (예: Python, PyTorch)
  preferredMajor String? // 우대전공 (예: 컴퓨터공학)
  capacity       Int? // 수용가능인원(명)

  memo String? // 기타협업메모

  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  @@map("collaborations")
}

// ── 3. 실무자정보 (기업 1:N) ────────────────────────────
model ContactPerson {
  id        String  @id @default(cuid())
  code      String  @unique // P-0001 ...
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name          String // 실무자이름
  dept          String? // 부서
  position      String? // 직책
  email         String?
  phone         String? // 연락처
  contactPref   String? // 선호연락방식: 미팅/전화/이메일
  lastContactAt String? // 최근컨택일 (yyyy-MM-dd)
  memo          String? // 관련메모
  note          String? // 비고

  isActive  Boolean  @default(true)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // 등록자(이메일)
  updatedBy String? // 수정자(이메일)

  histories ContactHistory[]

  @@index([companyId])
  @@map("contact_persons")
}

// ── 4. 컨택이력_협력성과 (기업 1:N, 실무자 1:N) ─────────
model ContactHistory {
  id        String         @id @default(cuid())
  code      String         @unique // H-0001 ...
  companyId String
  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  personId  String?
  person    ContactPerson? @relation(fields: [personId], references: [id], onDelete: SetNull)

  professor   String? // 교육원담당교수명
  business    String? // 사업단(관심사업분야): 중심대학/부트캠프
  contactDate String // 컨택일자 (yyyy-MM-dd)
  method      String? // 컨택방식: 미팅/전화/이메일/기타
  content     String? // 컨택내용
  histStatus  String  @default("논의중") // 컨택상태: 논의중/진행완료

  version   Int      @default(1)
  createdAt DateTime @default(now())
  createdBy String? // 등록자

  @@index([companyId])
  @@index([contactDate])
  @@map("contact_histories")
}

// ── DART 기업 고유번호(corp_code) 캐시 ──
// DART 는 corp_code 로만 회사를 조회하므로 회사명↔corp_code 매핑(~10만건)을
// 캐싱한다. (v1 의 _DartCorpCode 숨김시트를 테이블로 대체)
//   동기화: npx tsx scripts/sync-dart.ts  (한 달 1회 권장)
model DartCorpCode {
  corpCode  String  @id // 8자리 고유번호
  corpName  String
  normName  String // 정규화 회사명 (매칭용)
  stockCode String? // 상장사면 종목코드

  @@index([normName])
  @@map("dart_corp_codes")
}

// ── 카운터: 사람이 읽는 코드(C-001/P-0001/H-0001) 채번용 ──
// (DB 차원 원자적 증가. 시트의 _시스템 카운터를 대체)
model Counter {
  key   String @id // "company" | "person" | "history"
  value Int    @default(0)

  @@map("counters")
}

// ── 학생 (학번 키) ───────────────────────────────────────
model Student {
  studentNo  String   @id // 학번 (식별키)
  nameMasked String? // 마스킹 이름 (김*혁)
  department String? // 정컴/DS/비SW학과
  createdAt  DateTime @default(now())

  projects    ProjectStudent[]
  internships InternshipStudent[]

  @@map("students")
}

// ── 연구실 ───────────────────────────────────────────────
model Lab {
  id            String   @id @default(cuid())
  professorName String // 지도교수
  labName       String? // 연구실명
  affiliation   String? // 소속학과 (정컴/DS)
  createdAt     DateTime @default(now())

  projects Project[]

  @@index([professorName])
  @@map("labs")
}

// ── 분과 참조 (연도별 2버전) ─────────────────────────────
model Division {
  id      String @id @default(cuid())
  version String // 'old5'(구 5개) | 'new6'(신 6개)
  code    String // A~F
  name    String // 인공지능 등

  @@unique([version, code])
  @@map("divisions")
}

// ── 산학협력 프로젝트 ────────────────────────────────────
model Project {
  id              String  @id @default(cuid())
  year            Int? // 연도
  dept            String? // 정컴/DS
  category        String? // 학과졸업과제/교육원연계
  type            String? // 졸업과제/R&D/용역/캡스톤
  title           String? // 연구주제
  period          String? // 연구기간
  track           String? // SW중심대학 특성화트랙
  divisionVersion String? // 분과 버전
  divisionCode    String? // 분과 코드
  cntPhd          Int? // 박사생 수
  cntMaster       Int? // 석사생 수
  cntUndergrad    Int? // 학부생 수
  studentNamesRaw String? // 학번 없는 학부생 이름(콤마)

  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyNameRaw String? // 엑셀 원본 기업명 (미매칭 보존)
  labId          String?
  lab            Lab?     @relation(fields: [labId], references: [id], onDelete: SetNull)

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students ProjectStudent[]

  @@index([companyId])
  @@index([year])
  @@map("projects")
}

// ── 인턴십 ───────────────────────────────────────────────
model Internship {
  id           String  @id @default(cuid())
  year         Int?
  programName  String? // 프로그램명
  hostType     String? // 주관: 자체/학점연계
  method       String? // 교육방식
  domestic     String? // 국내외
  country      String?
  startDate    String? // 인턴시작일
  endDate      String? // 인턴종료일
  weeks        Int? // 인턴기간(주)
  hoursPerWeek Int? // 실습시간(1주 기준)
  credits      Int? // 인정학점
  cntCSE       Int? // 교육인원(정컴)
  cntDS        Int? // 교육인원(DS)
  cntNonSW     Int? // 교육인원(비SW학과)
  empSW        Int? // 연계취업자(SW)
  empNonSW     Int? // 연계취업자(비SW)

  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyNameRaw String? // 원본 기업명

  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students InternshipStudent[]

  @@index([companyId])
  @@index([year])
  @@map("internships")
}

// ── 프로젝트-학생 연결 (N:M) ─────────────────────────────
model ProjectStudent {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  studentNo String
  student   Student @relation(fields: [studentNo], references: [studentNo], onDelete: Cascade)

  @@unique([projectId, studentNo])
  @@index([studentNo])
  @@map("project_students")
}

// ── 인턴십-학생 연결 (N:M) ───────────────────────────────
model InternshipStudent {
  id           String     @id @default(cuid())
  internshipId String
  internship   Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  studentNo    String
  student      Student    @relation(fields: [studentNo], references: [studentNo], onDelete: Cascade)

  @@unique([internshipId, studentNo])
  @@index([studentNo])
  @@map("internship_students")
}

// ── 연도별 정량실적 현황판 (엑셀 '전체현황' 시트에서 읽은 값) ──
model YearStat {
  year                    Int      @id
  enrolledCSE             Int? // 정컴 재학생 수
  enrolledDS              Int? // DS 재학생 수
  industryTargetCSE       Int? // 산학 목표 기준치 인원(정컴)
  industryTargetDS        Int? // 산학 목표 기준치 인원(DS)
  internTargetCSE         Int? // 인턴십 목표 기준치 인원(정컴)
  internTargetDS          Int? // 인턴십 목표 기준치 인원(DS)
  industryTargetRatio     Float? // 산학협력 목표 비율
  industryAchievedRatio   Float? // 산학협력 달성 비율
  industryStudents        Int? // 산학협력 참여 학부생 수
  internshipTargetRatio   Float? // 인턴십 목표 비율
  internshipAchievedRatio Float? // 인턴십 달성 비율
  internshipStudents      Int? // 인턴십 참여 학부생 수
  updatedAt               DateTime @updatedAt

  @@map("year_stats")
}

// ── SW중심대학 사업 연차 ──────────────────────────────────
model SwcuYear {
  year        Int      @id // 사업연도 (2023~)
  university  String? // 학교명 (부산대학교)
  submittedAt String? // 제출일 텍스트
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  indicators SwcuIndicator[]
  raws       SwcuRaw[]

  @@map("swcu_years")
}

// ── 공통성과지표 (목표 대비 실적 + KMAC 검증) ─────────────
model SwcuIndicator {
  id             String   @id @default(cuid())
  year           Int
  yearRef        SwcuYear @relation(fields: [year], references: [year], onDelete: Cascade)
  area           String? // 영역
  name           String // 성과지표명
  unit           String? // 단위 (%, 명, 점, 건, 개)
  target         Float? // 당해년도 목표
  actual         Float? // 자체 실적
  verifiedActual Float? // KMAC 검증 실적 (있는 해만)
  verifyResult   String? // KMAC 검증결과 'O'/'X' (있는 해만)
  note           String?
  sortOrder      Int      @default(0)

  @@unique([year, name])
  @@index([year])
  @@map("swcu_indicators")
}

// ── 총괄 원시 집계값 ──────────────────────────────────────
model SwcuRaw {
  id        String   @id @default(cuid())
  year      Int
  yearRef   SwcuYear @relation(fields: [year], references: [year], onDelete: Cascade)
  scope     String // '공통' | 'AI'
  category  String? // 대분류
  label     String // 항목명
  value     Float?
  sortOrder Int      @default(0)

  @@unique([year, scope, sortOrder])
  @@index([year])
  @@map("swcu_raws")
}
